# Supply chain protection: package-lock.json pins exact versions.
# Run `npm audit` before upgrading dependencies.
registry=https://registry.npmjs.org/
# wterm@0.1.8 has a stale peer dep (@wterm/dom@0.1.7 vs 0.1.8).
# Harmless mismatch; remove this line once wterm publishes a fix.
legacy-peer-deps=true
