{
  "$schema": "https://raw.githubusercontent.com/nicklason/tauri-v2-schema/main/tauri.conf.json",
  "productName": "Agent of Empires",
  "version": "0.1.0",
  "identifier": "ai.mozilla.agent-of-empires",
  "build": {
    "frontendDist": "../web/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Agent of Empires",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "url": "about:blank"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
