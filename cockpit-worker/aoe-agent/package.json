{
  "name": "aoe-agent",
  "version": "0.0.1",
  "description": "Multi-provider ACP agent for Agent of Empires cockpit. Wraps Vercel AI SDK 6 in an ACP server.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "aoe-agent": "src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-strip-types src/index.ts",
    "test": "node --experimental-strip-types --test test/*.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/openai-compatible": "^2.0.42",
    "ai": "^6.0.185",
    "zod": "^4.3.6"
  },
  "license": "MIT"
}
