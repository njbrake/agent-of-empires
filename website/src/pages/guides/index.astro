---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base
  title="Guides - Agent of Empires"
  description="Guides and tutorials for Agent of Empires."
>
  <Nav />
  <main class="max-w-3xl mx-auto px-6 pt-32 pb-24">
    <span class="font-mono text-xs uppercase tracking-widest text-brand-600">Guides</span>
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 mt-3 font-display">Under construction</h1>
    <p class="text-lg text-gray-300 leading-relaxed mb-8">
      Written guides are on the way. In the meantime, check out our <a href="https://www.youtube.com/@agent-of-empires" target="_blank" rel="noopener" class="text-brand-500 hover:text-brand-400 transition-colors">YouTube channel</a> for tutorials and help videos.
    </p>
    <p class="text-lg text-gray-300 leading-relaxed mb-12">
      Have a guide you'd like to see? <a href="https://github.com/njbrake/agent-of-empires/issues" target="_blank" rel="noopener" class="text-brand-500 hover:text-brand-400 transition-colors">Open a GitHub issue</a> and let us know.
    </p>
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="https://www.youtube.com/@agent-of-empires" target="_blank" rel="noopener" class="btn-primary text-base px-8 py-3.5 inline-flex items-center justify-center gap-3">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        Watch on YouTube
      </a>
      <a href="https://github.com/njbrake/agent-of-empires/issues" target="_blank" rel="noopener" class="btn-secondary text-base px-8 py-3.5 inline-flex items-center justify-center gap-2">
        Request a guide
      </a>
    </div>
  </main>
  <Footer />
</Base>
